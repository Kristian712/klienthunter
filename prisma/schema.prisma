generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String?
  plan             Plan      @default(FREE)
  isAdmin          Boolean   @default(false)
  isVip            Boolean   @default(false)
  accessExpiresAt  DateTime?
  stripeCustomerId String?
  brevoApiKey      String?
  brevoSenderEmail String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  searches         Search[]
  savedResults     SavedResult[]
  createdCodes     InviteCode[] @relation("CreatedCodes")
  usedCode         InviteCode[] @relation("UsedCode")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

model Search {
  id        String   @id @default(cuid())
  userId    String
  query     String
  region    String
  createdAt DateTime @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  results BusinessResult[]
}

model BusinessResult {
  id            String   @id @default(cuid())
  searchId      String
  placeId       String
  name          String
  phone         String?
  email         String?
  address       String?
  website       String?
  hasWebsite    Boolean  @default(false)
  hasFacebook   Boolean  @default(false)
  hasInstagram  Boolean  @default(false)
  hasLinkedIn   Boolean  @default(false)
  facebookUrl   String?
  instagramUrl  String?
  linkedInUrl   String?
  websiteIsOld  Boolean  @default(false)
  websiteScore  Int      @default(50)
  websiteAgeNote String  @default("")
  reviewCount   Int      @default(0)
  rating        Float?
  googleMapsUrl String?
  category      String?
  source        String   @default("google")
  rawData       Json?
  createdAt     DateTime @default(now())

  search  Search        @relation(fields: [searchId], references: [id], onDelete: Cascade)
  savedBy SavedResult[]
}

model InviteCode {
  id                    String    @id @default(cuid())
  code                  String    @unique
  note                  String?
  createdBy             String
  usedBy                String?
  usedAt                DateTime?
  expiresAt             DateTime?
  accessDurationMinutes Int?
  createdAt             DateTime  @default(now())

  creator    User  @relation("CreatedCodes", fields: [createdBy], references: [id], onDelete: Cascade)
  usedByUser User? @relation("UsedCode",    fields: [usedBy],    references: [id], onDelete: SetNull)
}

model SavedResult {
  id               String   @id @default(cuid())
  userId           String
  businessResultId String
  note             String?
  createdAt        DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessResult BusinessResult @relation(fields: [businessResultId], references: [id], onDelete: Cascade)

  @@unique([userId, businessResultId])
}
